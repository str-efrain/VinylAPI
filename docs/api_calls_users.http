### Get all users
GET http://localhost:3000/api/users
x-auth-token: REPLACE_WITH_ADMIN_TOKEN

### Get all users without token
GET http://localhost:3000/api/users

### Get all users with invalid token
GET http://localhost:3000/api/users
x-auth-token: invalid-token

### Get all users with regular user token
GET http://localhost:3000/api/users
x-auth-token: REPLACE_WITH_USER_TOKEN

### Get user by ID
GET http://localhost:3000/api/users/REPLACE_WITH_USER_ID
x-auth-token: REPLACE_WITH_ADMIN_TOKEN

### Get user by invalid ID
GET http://localhost:3000/api/users/abc
x-auth-token: REPLACE_WITH_ADMIN_TOKEN

### Get user by valid-looking but missing ID
GET http://localhost:3000/api/users/507f1f77bcf86cd799439011
x-auth-token: REPLACE_WITH_ADMIN_TOKEN

### Update user
PATCH http://localhost:3000/api/users/REPLACE_WITH_USER_ID
x-auth-token: REPLACE_WITH_ADMIN_TOKEN
Content-Type: application/json

{
  "name": "Updated Test User",
  "profile": {
    "displayName": "Updated Collector",
    "bio": "Collects rock and metal records.",
    "country": "Belgium"
  },
  "preferences": {
    "favoriteGenres": ["Rock", "Metal"],
    "favoriteFormats": ["LP", "Box Set"]
  }
}

### Update user with invalid ID
PATCH http://localhost:3000/api/users/abc
x-auth-token: REPLACE_WITH_ADMIN_TOKEN
Content-Type: application/json

{
  "name": "Updated Test User"
}

### Update user with invalid data
PATCH http://localhost:3000/api/users/REPLACE_WITH_USER_ID
x-auth-token: REPLACE_WITH_ADMIN_TOKEN
Content-Type: application/json

{
  "name": "A"
}

### Update user trying to change role
PATCH http://localhost:3000/api/users/REPLACE_WITH_USER_ID
x-auth-token: REPLACE_WITH_ADMIN_TOKEN
Content-Type: application/json

{
  "role": "admin"
}

### Delete user
DELETE http://localhost:3000/api/users/REPLACE_WITH_USER_ID
x-auth-token: REPLACE_WITH_ADMIN_TOKEN

### Delete user with invalid ID
DELETE http://localhost:3000/api/users/abc
x-auth-token: REPLACE_WITH_ADMIN_TOKEN

### Delete user with valid-looking but missing ID
DELETE http://localhost:3000/api/users/507f1f77bcf86cd799439011
x-auth-token: REPLACE_WITH_ADMIN_TOKEN

### Delete user without token
DELETE http://localhost:3000/api/users/REPLACE_WITH_USER_ID

### Delete user with regular user token
DELETE http://localhost:3000/api/users/REPLACE_WITH_USER_ID
x-auth-token: REPLACE_WITH_USER_TOKEN

### Update user role
PATCH http://localhost:3000/api/users/REPLACE_WITH_USER_ID/role
x-auth-token: REPLACE_WITH_ADMIN_TOKEN
Content-Type: application/json

{
  "role": "admin"
}

### Update user role to regular user
PATCH http://localhost:3000/api/users/REPLACE_WITH_USER_ID/role
x-auth-token: REPLACE_WITH_ADMIN_TOKEN
Content-Type: application/json

{
  "role": "user"
}

### Update user role with invalid role
PATCH http://localhost:3000/api/users/REPLACE_WITH_USER_ID/role
x-auth-token: REPLACE_WITH_ADMIN_TOKEN
Content-Type: application/json

{
  "role": "superadmin"
}

### Update user role without token
PATCH http://localhost:3000/api/users/REPLACE_WITH_USER_ID/role
Content-Type: application/json

{
  "role": "admin"
}

### Update user role with regular user token
PATCH http://localhost:3000/api/users/REPLACE_WITH_USER_ID/role
x-auth-token: REPLACE_WITH_USER_TOKEN
Content-Type: application/json

{
  "role": "admin"
}
